# IWAKY Panel Financiero — Configuración
# Copia este archivo como .env y cambia los valores

# Puerto del servidor
PORT=3000

# Clave secreta para JWT (CAMBIA ESTO por algo largo y aleatorio)
JWT_SECRET=cambia-esto-por-una-clave-segura-muy-larga-2026

# Duración de la sesión (en horas)
SESSION_HOURS=72

# Dominio (para cookies seguras en producción)
DOMAIN=panel.tudominio.com

# Entorno: development o production
NODE_ENV=production
